# Copy to .env and fill. Each section notes where to obtain the value.
# Comments live on their OWN lines — keep value lines clean (no inline # comments),
# this python-dotenv build does not strip trailing comments.

# ── Google / Gemini ──
# LOCAL DEV (recommended): a Gemini API key — aistudio.google.com/apikey. No gcloud, no SA key.
GEMINI_API_KEY=
# Local model: free-tier-friendly flash-lite (pro is blocked; flash can 503 under load).
# Deployed agent uses Gemini 3 on Vertex.
VERTEX_GEMINI_MODEL=gemini-2.5-flash-lite
#
# DEPLOY-TIME Vertex (Phase 6) — the Cloud Run agent uses its attached service account (keyless).
# Leave blank for local API-key dev.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Set "true" to force Vertex locally (needs gcloud ADC). Blank = use GEMINI_API_KEY.
GOOGLE_GENAI_USE_VERTEXAI=
# Only for a local key file (blocked by your org policy → leave blank).
GOOGLE_APPLICATION_CREDENTIALS=
# Embeddings: Voyage AI (MongoDB-native). Free key at voyageai.com.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5-lite
EMBEDDING_DIMS=1024

# ── MongoDB Atlas (mandatory; M0 free tier supports Vector Search) ──
MONGODB_URI=
MONGODB_DB=sprint0
PAST_PROJECTS_COLLECTION=PastProjects
DEVELOPER_PROFILES_COLLECTION=DeveloperProfiles
PAST_PROJECTS_VECTOR_INDEX=pp_vector_index
DEVELOPER_VECTOR_INDEX=dev_vector_index

# ── GitLab (mandatory) ──
GITLAB_BASE_URL=https://gitlab.com
# Personal or Group Access Token, scope: api
GITLAB_TOKEN=
# Sacrificial top-level group; reset_demo wipes its projects between demos.
GITLAB_DEMO_GROUP=orchestrator-demo

# ── Orchestrator ──
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=8000

# ── Phase 6 hybrid deploy (set on Cloud Run; leave blank for local = fully live) ──
# "true" on the public service → paid Gemini + real GitLab dispatch are canned, MongoDB MCP stays live.
# Blank/unset (local dev, tests) → fully live, current behavior unchanged.
DEMO_MODE=
# The judge-private unlock secret. The magic link is  https://<frontend>/?unlock=<this value>
LIVE_UNLOCK_TOKEN=
# Demo dispatch points here instead of creating a real GitLab project (pre-make + seed-tag this repo).
DEMO_SHOWCASE_URL=
DEMO_SHOWCASE_PID=
# Prod frontend origin added to CORS (e.g. https://<project>.web.app).
FRONTEND_ORIGIN=
# Frontend build-time only (Vite): the deployed gateway URL, e.g. https://sprint0-gateway-xxxx.run.app
VITE_API_BASE=
